# ─────────────────────────────────────────────────────────────────────────────
# Mizan environment configuration
# Copy to `.env`. The app runs fully without any of these set (deterministic
# MockLLM is used when no model key is present).
# ─────────────────────────────────────────────────────────────────────────────

# --- LLM (optional) ----------------------------------------------------------
# If unset, Mizan uses a deterministic MockLLM for extraction / memos.
# ANTHROPIC_API_KEY=sk-ant-...
MIZAN_LLM_PROVIDER=mock            # mock | anthropic
MIZAN_LLM_MODEL=claude-opus-4-8    # used only when provider=anthropic

# --- Database ----------------------------------------------------------------
# SQLite by default. Set a postgresql:// URL later to switch (repository-ready).
MIZAN_DATABASE_URL=sqlite:///./mizan.db

# --- Policy knobs (defaults match Sheikh Zayed Housing Programme rules) -------
MIZAN_MAX_DEDUCTION_RATIO=0.20     # monthly deduction must not exceed 20% income
MIZAN_SLA_WORKING_DAYS=5           # legacy manual SLA, used for the SLA clock

# --- Confidence routing ------------------------------------------------------
MIZAN_AUTO_APPROVE_CONFIDENCE=0.75 # >= this AND straight-through eligible -> auto
MIZAN_API_BASE_URL=http://localhost:8000
